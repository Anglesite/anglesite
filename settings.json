      "Bash(npm run ai-check)",
      "Bash(npm run ai-setup)",
      "Bash(npm run ai-cleanup)",
      "Bash(npm install *)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm outdated)",
      "Bash(npm audit *)",
      "Bash(npx wrangler *)",
      "Bash(npx astro check)",
