---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Comments from "../../components/Comments.astro";
import { getCollection, render } from "astro:content";
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  ...(post.data.image && {
    image: new URL(post.data.image, Astro.site).toString(),
  }),
};

// Comments are opt-in per site (.site-config) and per post (frontmatter).
const configPath = resolve(process.cwd(), ".site-config");
const config = existsSync(configPath) ? readFileSync(configPath, "utf-8") : "";
const read = (key: string) => config.match(new RegExp(`^${key}=(.+)$`, "m"))?.[1]?.trim();
const commentsProvider = read("COMMENTS_PROVIDER");
const showComments = commentsProvider === "giscus" && post.data.comments !== false;
const giscusProps = showComments
  ? {
      repo: read("GISCUS_REPO") ?? "",
      repoId: read("GISCUS_REPO_ID") ?? "",
      category: read("GISCUS_CATEGORY") ?? "Comments",
      categoryId: read("GISCUS_CATEGORY_ID") ?? "",
      mapping: (read("GISCUS_MAPPING") ?? "pathname") as
        | "pathname"
        | "url"
        | "title"
        | "og:title",
      theme: read("GISCUS_THEME") ?? "preferred_color_scheme",
      reactionsOnly: read("GISCUS_REACTIONS_ONLY") === "true",
    }
  : null;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
  jsonLd={articleJsonLd}
>
  <article class="h-entry">
    <h1 class="p-name">{post.data.title}</h1>
    <time
      class="dt-published"
      datetime={post.data.publishDate.toISOString()}
    >
      {post.data.publishDate.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </time>

    {
      post.data.image && (
        <img
          src={post.data.image}
          alt={post.data.imageAlt || ""}
          class="u-photo"
        />
      )
    }

    <div class="e-content">
      <Content />
    </div>

    {
      post.data.tags.length > 0 && (
        <ul class="tags">
          {post.data.tags.map((tag) => (
            <li class="p-category">{tag}</li>
          ))}
        </ul>
      )
    }

    {
      post.data.syndication.length > 0 && (
        <ul class="syndication">
          {post.data.syndication.map((url) => (
            <li>
              <a href={url} class="u-syndication" rel="syndication">
                {new URL(url).hostname}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </article>

  {/* Webmentions are injected here at the edge by worker/site-entry.js when
      WEBMENTION_INBOX holds verified mentions of this page. Empty in the static
      build; populated per-request without client JS. See docs/indieweb.md. */}
  <div id="webmentions"></div>

  {giscusProps && giscusProps.repoId && giscusProps.categoryId && (
    <Comments {...giscusProps} />
  )}
</BaseLayout>
