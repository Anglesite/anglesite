---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AudioPlayer from "../../components/AudioPlayer.astro";
import { getCollection, render } from "astro:content";

export const prerender = true;

export async function getStaticPaths() {
  const episodes = await getCollection("episodes", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return episodes.map((episode) => ({
    params: { slug: episode.id },
    props: { episode },
  }));
}

const { episode } = Astro.props;
const { Content } = await render(episode);

const audioSrc = /^https?:\/\//.test(episode.data.audioUrl)
  ? episode.data.audioUrl
  : new URL(episode.data.audioUrl, Astro.site).toString();

function youtubeId(url?: string): string | undefined {
  if (!url) return undefined;
  // Matches https://www.youtube.com/watch?v=XXXX, https://youtu.be/XXXX,
  // and https://www.youtube.com/embed/XXXX. Returns the 11-char video id.
  const m =
    /(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/.exec(
      url,
    );
  return m ? m[1] : undefined;
}
const ytId = youtubeId(episode.data.youtubeUrl);

function isoDuration(d?: string): string | undefined {
  if (!d) return undefined;
  const parts = d.split(":").map((n) => parseInt(n, 10));
  if (parts.some(Number.isNaN)) return undefined;
  let h = 0,
    m = 0,
    s = 0;
  if (parts.length === 3) [h, m, s] = parts;
  else if (parts.length === 2) [m, s] = parts;
  else return undefined;
  return `PT${h ? h + "H" : ""}${m ? m + "M" : ""}${s ? s + "S" : ""}`;
}

const episodeJsonLd = {
  "@context": "https://schema.org",
  "@type": "PodcastEpisode",
  name: episode.data.title,
  datePublished: episode.data.publishDate.toISOString(),
  description: episode.data.description,
  url: new URL(`/podcast/${episode.id}/`, Astro.site).toString(),
  ...(isoDuration(episode.data.duration) && {
    duration: isoDuration(episode.data.duration),
  }),
  associatedMedia: {
    "@type": "AudioObject",
    contentUrl: audioSrc,
    encodingFormat: episode.data.audioType,
  },
  partOfSeries: {
    "@type": "PodcastSeries",
    name: "Podcast",
    url: new URL("/podcast/", Astro.site).toString(),
    webFeed: new URL("/podcast/rss.xml", Astro.site).toString(),
  },
  ...(episode.data.guests.length > 0 && {
    actor: episode.data.guests.map((name) => ({ "@type": "Person", name })),
  }),
};
---

<BaseLayout
  title={episode.data.title}
  description={episode.data.description}
  image={episode.data.image}
  jsonLd={episodeJsonLd}
>
  <article class="h-entry episode">
    <header>
      <h1 class="p-name">{episode.data.title}</h1>
      <p class="episode__meta">
        <time
          class="dt-published"
          datetime={episode.data.publishDate.toISOString()}
        >
          {episode.data.publishDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {episode.data.duration && <span> · {episode.data.duration}</span>}
        {episode.data.season && episode.data.episodeNumber && (
          <span> · S{episode.data.season}E{episode.data.episodeNumber}</span>
        )}
        {episode.data.episodeType !== "full" && (
          <span> · {episode.data.episodeType}</span>
        )}
      </p>
      {episode.data.guests.length > 0 && (
        <p class="episode__guests">
          Featuring: {episode.data.guests.join(", ")}
        </p>
      )}
    </header>

    <AudioPlayer
      src={audioSrc}
      type={episode.data.audioType}
      title={episode.data.title}
    />

    {ytId && (
      <figure class="episode__video">
        <iframe
          class="episode__video-iframe"
          src={`https://www.youtube-nocookie.com/embed/${ytId}`}
          title={`Video: ${episode.data.title}`}
          loading="lazy"
          allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          referrerpolicy="strict-origin-when-cross-origin"
        ></iframe>
      </figure>
    )}

    <p class="episode__subscribe">
      <a href="/podcast/subscribe/">Subscribe</a> ·
      <a href={audioSrc} download>Download audio</a>
    </p>

    <div class="e-content episode__notes">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .episode__meta {
    color: var(--color-muted, #666);
    font-size: 0.875rem;
  }
  .episode__guests {
    font-style: italic;
  }
  .episode__subscribe {
    margin: 0.5rem 0 1.5rem;
    font-size: 0.9rem;
  }
  .episode__video {
    margin: 0 0 1.5rem;
    aspect-ratio: 16 / 9;
  }
  .episode__video-iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }
  .episode__notes :global(h2),
  .episode__notes :global(h3) {
    scroll-margin-top: 1rem;
  }
  /* Timestamp anchors are clickable buttons in show notes/transcripts. */
  .episode__notes :global(a[href^="#t-"]) {
    font-variant-numeric: tabular-nums;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    text-decoration: none;
    border-bottom: 1px dotted currentColor;
  }
</style>
