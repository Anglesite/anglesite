---
interface Props {
  goal: number;
  raised: number;
  label?: string;
  currency?: string;
}
const { goal, raised, label, currency = "USD" } = Astro.props;
const safeGoal = Math.max(goal, 1);
const pct = Math.min(100, Math.max(0, (raised / safeGoal) * 100));
const fmt = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency,
  maximumFractionDigits: 0,
});
---
<figure class="donation-goal" role="group" aria-label="Fundraising progress">
  <figcaption class="donation-goal__caption">
    <strong>{fmt.format(raised)}</strong> raised of {fmt.format(goal)} goal
    {label && <span class="donation-goal__label"> — {label}</span>}
  </figcaption>
  <div
    class="donation-goal__track"
    role="progressbar"
    aria-valuenow={Math.round(pct)}
    aria-valuemin="0"
    aria-valuemax="100"
  >
    <div class="donation-goal__fill" style={`width: ${pct}%`}></div>
  </div>
</figure>
