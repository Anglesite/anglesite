---
/**
 * Premium content gate for inline sections.
 *
 * Wrap a portion of a page in <Premium> to hide it from non-members.
 * The wrapper renders a hidden <template> containing the gated HTML —
 * a tiny inline script promotes it to live DOM only after the
 * membership Worker confirms the visitor's signed cookie via
 * `${MEMBERSHIP_WORKER_URL}/verify`.
 *
 * For whole-page gating, prefer `tier: premium` in the page's
 * frontmatter and let the Pages middleware handle it. Use this
 * component only when one page mixes public and premium sections.
 */

import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";

interface Props {
  /** Short text shown to non-members in place of the gated content. */
  teaser?: string;
}

const { teaser = "This section is for members." } = Astro.props as Props;

const configPath = resolve(process.cwd(), ".site-config");
const config = existsSync(configPath) ? readFileSync(configPath, "utf-8") : "";
const workerUrl = config.match(/^MEMBERSHIP_WORKER_URL=(.+)$/m)?.[1]?.trim() ?? "";
const returnTo = Astro.url.pathname + Astro.url.search;
---

<div class="premium-gate" data-worker={workerUrl} data-return={returnTo}>
  <noscript>
    <p class="premium-teaser">{teaser}</p>
    <p>
      <a href={`/unlock?return=${encodeURIComponent(returnTo)}`}>Unlock</a>
    </p>
  </noscript>

  <div class="premium-public" hidden={false}>
    <p class="premium-teaser">{teaser}</p>
    <p>
      <a class="button" href={`/unlock?return=${encodeURIComponent(returnTo)}`}>
        Unlock
      </a>
    </p>
  </div>

  <template class="premium-content">
    <slot />
  </template>
</div>

<script>
  /* Inline runtime is the only first-party JS this component adds. */
  for (const gate of document.querySelectorAll<HTMLElement>(".premium-gate")) {
    const workerUrl = gate.dataset.worker;
    if (!workerUrl) continue;
    fetch(`${workerUrl}/verify`, { credentials: "include" })
      .then((r) => (r.ok ? r.json() : { ok: false }))
      .then((data) => {
        if (!data || data.ok !== true) return;
        const tpl = gate.querySelector<HTMLTemplateElement>("template.premium-content");
        const pub = gate.querySelector<HTMLElement>(".premium-public");
        if (tpl && pub) {
          pub.hidden = true;
          gate.appendChild(tpl.content.cloneNode(true));
        }
      })
      .catch(() => {
        /* leave the public teaser visible */
      });
  }
</script>
