---
/**
 * Vanilla audio player for podcast episodes.
 *
 * Wraps the native <audio> element with progressive enhancement:
 * timestamp links in the show notes (anchors like #t-12-34) seek the
 * player when clicked. No third-party JavaScript.
 *
 * Generated/used by /anglesite:podcast.
 */
interface Props {
  src: string;
  type?: string;
  title?: string;
  preload?: "none" | "metadata" | "auto";
}
const { src, type = "audio/mpeg", title, preload = "metadata" } = Astro.props;
---

<figure class="audio-player">
  {title && <figcaption class="audio-player__title">{title}</figcaption>}
  <audio
    class="audio-player__el"
    controls
    preload={preload}
    aria-label={title ? `Audio player: ${title}` : "Audio player"}
  >
    <source src={src} type={type} />
    <p>
      Your browser does not support audio playback.
      <a href={src} download>Download the audio file</a>.
    </p>
  </audio>
</figure>

<script is:inline>
  // Click on a [12:34](#t-12-34) link → seek the page's audio player.
  (function () {
    function parseTime(hash) {
      var m = /^#t-(?:(\d+)-)?(\d+)-(\d+)$/.exec(hash);
      if (!m) return null;
      var h = m[1] ? parseInt(m[1], 10) : 0;
      var min = parseInt(m[2], 10);
      var s = parseInt(m[3], 10);
      return h * 3600 + min * 60 + s;
    }
    document.addEventListener("click", function (e) {
      var a = e.target.closest && e.target.closest('a[href^="#t-"]');
      if (!a) return;
      var t = parseTime(a.getAttribute("href"));
      if (t == null) return;
      var audio = document.querySelector(".audio-player__el");
      if (!audio) return;
      e.preventDefault();
      audio.currentTime = t;
      audio.play().catch(function () {});
    });
  })();
</script>

<style>
  .audio-player {
    margin: 0 0 1.5rem;
  }
  .audio-player__title {
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .audio-player__el {
    width: 100%;
  }
</style>
