{
  "title": "Request a callback",
  "slug": "callback",
  "description": "Leave your number and we'll call you back.",
  "successMessage": "Got it — we'll call you soon.",
  "rateLimitSeconds": 120,
  "fields": [
    { "name": "name", "label": "Name", "type": "text", "required": true, "maxLength": 100 },
    {
      "name": "phone",
      "label": "Phone",
      "type": "tel",
      "required": true,
      "pattern": "^[0-9 +()\\-]{7,20}$",
      "helpText": "Numbers, spaces, +, (, ), and - only"
    },
    {
      "name": "bestTime",
      "label": "Best time to call",
      "type": "select",
      "required": true,
      "options": [
        "Morning (9am – 12pm)",
        "Afternoon (12pm – 5pm)",
        "Evening (5pm – 8pm)",
        "Anytime"
      ]
    },
    {
      "name": "topic",
      "label": "What's it about?",
      "type": "textarea",
      "required": false,
      "maxLength": 1000
    }
  ]
}
