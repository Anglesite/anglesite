{
  "title": "Quick survey",
  "slug": "survey",
  "description": "Three short questions — should take less than a minute.",
  "successMessage": "Thanks for your feedback!",
  "rateLimitSeconds": 60,
  "fields": [
    {
      "name": "satisfaction",
      "label": "How satisfied are you?",
      "type": "scale",
      "required": true,
      "min": 1,
      "max": 5,
      "helpText": "1 = not at all, 5 = extremely"
    },
    {
      "name": "recommend",
      "label": "Would you recommend us?",
      "type": "radio",
      "required": true,
      "options": ["Definitely", "Maybe", "Probably not"]
    },
    {
      "name": "topics",
      "label": "What would you like to hear more about?",
      "type": "checkbox",
      "required": false,
      "options": ["New products", "Tips & tutorials", "Behind the scenes", "Sales & promos"]
    },
    {
      "name": "comments",
      "label": "Anything else?",
      "type": "textarea",
      "required": false,
      "maxLength": 1000
    }
  ]
}
